@inproceedings{yangUnifiedLanguagedrivenZeroshot2024,
  author = {Yang, S and Tian, Z and Jiang, L and Jia, J},
  title = {Unified language-driven zero-shot domain adaptation},
  booktitle = {{CVPR}},
  year = {2024},
  url = {http://openaccess.thecvf.com/content/CVPR2024/html/Yang_Unified_Language-driven_Zero-shot_Domain_Adaptation_CVPR_2024_paper.html},
  abstract = {This paper introduces Unified Language-driven Zero-shot Domain Adaptation (ULDA) a novel task setting that enables a single model to adapt to diverse target domains without explicit domain-ID knowledge. We identify the constraints in the existing language-driven zero-shot domain adaptation task particularly the requirement for domain IDs and domain-specific models which may restrict flexibility and scalability. To overcome these issues we propose a new framework for ULDA consisting of Hierarchical Context Alignment (HCA) Domain Consistent Representation Learning (DCRL) and Text-Driven Rectifier (TDR). These components work synergistically to align simulated features with target text across multiple visual levels retain semantic correlations between different regional representations and rectify biases between simulated and real target visual features respectively. Our extensive empirical evaluations demonstrate that this framework achieves competitive performance in both settings surpassing even the model that requires domain-ID showcasing its superiority and generalization ability. The proposed method is not only effective but also maintains practicality and efficiency as it does not introduce additional computational costs during inference. The code is available on the project website.},
  keywords = {Year: 2024, Venue: CVPR, Primary Task Type: Grounded Segmentation, Primary Method Category: Region-Word Grounding, Method Category: Region-Word Grounding, Method Category: Mask-Text Alignment, Method Category: Distillation / Efficient Segmentation, Primary Foundation Model: None / Task-specific model, Foundation Model: None / Task-specific model},
  note = {Data-CID: L5QsLnOhI1IJ Google Scholar cited by: 49 Filtered venue: CVPR Rejected reason: allowed venue/year but title lacks explicit segmentation plus reasoning/LLM/instruction signal Source rejected file: gs\_reasoning\_seg\_rejected\_allowed\_venue\_topic.json Source search prefix: gs\_reasoning\_seg Scholar metadata: S Yang, Z Tian, L Jiang, J Jia - Proceedings of the IEEE …, 2024 - openaccess.thecvf.com Scholar result number: 811 Scholar full text: https://openaccess.thecvf.com/content/CVPR2024/papers/Yang\_Unified\_Language-driven\_Zero-shot\_Domain\_Adaptation\_CVPR\_2024\_paper.pdf},
